cabinet main
require "fmt"

struct ParentGo
    id Int
end

struct ChildGo
    ParentGo
    name String
end

def (c ChildGo) greetGo()
    fmt::Println("Valid Struct (Go-style):", c.name)
end

class ParentRuby
    id Int
end

class ChildRuby < ParentRuby
    name String

    def greet()
        fmt::Println("Valid Class (Ruby-style):", @name)
    end
end

def main()
    let s = ChildGo{name: "Go"}
    s.greetGo()

    let c = ChildRuby{name: "Ruby"}
    c.greet()
end
